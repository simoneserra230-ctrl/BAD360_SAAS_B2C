# ═══════════════════════════════════════════════════════════════════
#  BAD.S Unified Platform — Variabili d'Ambiente
#  Copia questo file come ".env" e compila i valori reali
#  NON committare mai il file .env su Git!
# ═══════════════════════════════════════════════════════════════════

# ── Anthropic API (OBBLIGATORIO) ───────────────────────────────────
# Ottieni la tua chiave su: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-INSERISCI_QUI_LA_TUA_CHIAVE

# ── Supabase (Database cloud) ──────────────────────────────────────
# Crea progetto su: https://supabase.com
# Project Settings → API → Project URL
SUPABASE_URL=https://TUID.supabase.co
# Project Settings → API → service_role key (NON la anon key!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.INSERISCI_QUI

# ── Configurazione App ─────────────────────────────────────────────
APP_SECRET=cambia-questo-valore-in-produzione-con-stringa-casuale-lunga
APP_ENV=development
# development | production
DEBUG=true

# ── CORS - Origini consentite ──────────────────────────────────────
# In sviluppo lascia così. In produzione: https://tuodominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# ── Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Numero worker uvicorn (production: numero CPU × 2 + 1)
WORKERS=1

# ── Opzionali: Integrazioni Esterne ───────────────────────────────

# Twilio — SMS/WhatsApp alert HACCP temperatura
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+39XXXXXXXXXX
# ALERT_SMS_TO=+39XXXXXXXXXX

# Sentry — Error tracking produzione
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX

# Stripe — Pagamenti abbonamento SaaS
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Redis — Cache e task queue (opzionale per performance)
# REDIS_URL=redis://localhost:6379/0

# ── Limiti API ─────────────────────────────────────────────────────
# Numero massimo richieste AI per ora per IP
AI_RATE_LIMIT_PER_HOUR=60
# Max token per risposta AI
AI_MAX_TOKENS=2048

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# File di log (lascia vuoto per solo stdout)
# LOG_FILE=./logs/bads_platform.log
